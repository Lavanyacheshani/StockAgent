# ============================================================
# StockAgent — Required Environment Variables
# Copy this file to .env and fill in your real API keys.
# NEVER commit .env to version control.
# ============================================================

# OpenAI (required for all LLM agents)
OPENAI_API_KEY=sk-...

# LangSmith — observability & tracing (required)
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=stock-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_TRACING_V2=true

# Alpha Vantage — financial time-series data (required)
# Free tier: 5 req/min, 100 req/day  https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=YOUR_ALPHA_VANTAGE_KEY

# Serper — Google News search for sentiment (required)
# https://serper.dev
SERPER_API_KEY=YOUR_SERPER_API_KEY

# Firecrawl — web scraping for sentiment agent (required)
# https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...
